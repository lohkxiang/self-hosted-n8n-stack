# Reference only — run setup.sh and it fills in all values automatically.
# You do not need to edit this file.
#
# How each variable gets set:
#   prompted by setup.sh  — you type it in when running setup
#   auto-generated        — setup.sh generates a secure random value
#   auto-calculated       — setup.sh calculates based on your VPS RAM
#   fixed default         — hardcoded, no input needed

# --- prompted by setup.sh ---
# Hostname only — no https:// or http://
# Final URL will be https://n8n.[DOMAIN_NAME]
DOMAIN_NAME=srv123.hstgr.cloud
SSL_EMAIL=you@example.com

# --- fixed defaults ---
SUBDOMAIN=n8n
POSTGRES_USER=n8n
POSTGRES_DB=n8n_db

# --- auto-generated by setup.sh ---
POSTGRES_PASSWORD=
N8N_ENCRYPTION_KEY=

# --- fixed default ---
EXECUTIONS_DATA_MAX_AGE=168

# --- auto-calculated by setup.sh based on VPS RAM ---
N8N_WORKER_COUNT=
TRAEFIK_MEMORY_LIMIT=
TRAEFIK_CPU_LIMIT=
POSTGRES_MEMORY_LIMIT=
POSTGRES_CPU_LIMIT=
REDIS_MEMORY_LIMIT=
REDIS_CPU_LIMIT=
N8N_MEMORY_LIMIT=
N8N_CPU_LIMIT=
N8N_WORKER_MEMORY_LIMIT=
N8N_WORKER_CPU_LIMIT=
WATCHTOWER_MEMORY_LIMIT=
WATCHTOWER_CPU_LIMIT=

# --- prompted by setup.sh, optional ---
WATCHTOWER_NOTIFICATION_URL=
