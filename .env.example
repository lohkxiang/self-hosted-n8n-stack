# Domain
# Use your own domain (e.g. yourdomain.com) or your VPS provider's default hostname (e.g. srv123.hstgr.cloud)
# Hostinger users: find this in your VPS dashboard. No custom domain needed.
DOMAIN_NAME=yourdomain.com
SUBDOMAIN=n8n
# Your email address — used by Let's Encrypt to notify you if your SSL certificate is about to expire
SSL_EMAIL=you@yourdomain.com

# Postgres
POSTGRES_USER=n8n
POSTGRES_PASSWORD=changeme
POSTGRES_DB=n8n_db

# n8n
N8N_ENCRYPTION_KEY=changeme_generate_a_random_32char_string
N8N_WORKER_COUNT=1
# How long to keep execution history (hours) — prevents database bloat. Default: 168 (7 days)
EXECUTIONS_DATA_MAX_AGE=168

# Watchtower — optional, remove WATCHTOWER_NOTIFICATION_URL to disable email alerts
# Format: smtp://user:password@host:port/?from=from@domain.com&to=to@domain.com
WATCHTOWER_NOTIFICATION_URL=
